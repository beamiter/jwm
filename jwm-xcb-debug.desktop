[Desktop Entry]
Name=JWM Debug (xcb backend via daemon)
Comment=JWM Window Manager managed by jwm-tool with verbose debug logging
Exec=env JWM_BACKEND=xcb JWM_WATERLILY_ENABLED=1 JWM_DEBUG_KEYS=1 JWM_DEBUG_DRAG=1 RUST_LOG=debug,smithay=warn,libseat=warn,drm=warn RUST_BACKTRACE=1 /usr/local/bin/jwm-tool daemon
TryExec=/usr/local/bin/jwm-tool
Type=Application
Categories=System;
StartupNotify=false
NoDisplay=false
